---
import Base from '../layouts/Base.astro';
import { getSocials } from '../socials';
const socials = getSocials('en');
---
<Base title="Contact" description="Get in touch.">
  <section class="max-w-3xl mx-auto px-4 sm:px-6 py-16 sm:py-24">
    <h1 data-animate class="text-3xl sm:text-4xl font-bold tracking-tight mb-4">Contact</h1>
    <p data-animate data-animate-delay="100" class="text-[var(--color-text-secondary)] text-lg mb-8">Say hi, collaborate, or ask a question.</p>
    <div class="space-y-2">
      <a data-animate data-animate-delay="150" href="mailto:hello@hyrahmo.com" class="flex items-center gap-4 p-4 bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl hover:border-[var(--color-text-muted)] transition-all hover:-translate-y-0.5">
        <span class="font-mono text-xs text-[var(--color-text-muted)] w-20">Email</span>
        <span class="text-[var(--color-accent)]">hello@hyrahmo.com</span>
      </a>
      {socials.map((s, i) => (
        <a data-animate data-animate-delay={200 + i * 50} href={s.url} target="_blank" rel="noopener" class="flex items-center gap-4 p-4 bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl hover:border-[var(--color-text-muted)] transition-all hover:-translate-y-0.5">
          <span class="font-mono text-xs text-[var(--color-text-muted)] w-20">{s.label}</span>
          <span class="text-[var(--color-accent)]">{s.handle}</span>
        </a>
      ))}
    </div>
  </section>
</Base>
