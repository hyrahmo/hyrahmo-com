---
import Base from '../layouts/Base.astro';
---
<Base title="Home" description="Builder, thinker, systems. Projects, open research, and a multilingual knowledge base.">
  <section class="min-h-[85vh] flex items-center">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 py-20 sm:py-32">
      <p data-animate class="font-mono text-sm text-[var(--color-text-muted)] mb-5">builder · thinker · systems</p>
      <h1 data-animate data-animate-delay="100" class="text-[clamp(2.5rem,7vw,4rem)] font-bold leading-[1.1] tracking-tight mb-5">
        I build things and<br class="hidden sm:block"/> share what I learn.
      </h1>
      <p data-animate data-animate-delay="200" class="text-[var(--color-text-secondary)] max-w-sm mb-8">
        Projects, notes, and ideas — one place.
      </p>
      <div data-animate data-animate-delay="300" class="flex gap-3">
        <a href="/projects" class="px-5 py-2.5 rounded-lg font-medium text-sm hover:opacity-90 transition-all hover:-translate-y-0.5" style="background:var(--color-accent);color:var(--color-bg)">Projects</a>
        <a href="/blog" class="px-5 py-2.5 border border-[var(--color-border)] rounded-lg text-sm text-[var(--color-text)] hover:border-[var(--color-text-muted)] transition-all hover:-translate-y-0.5">Blog</a>
        <a href="/kb/" class="px-5 py-2.5 border border-[var(--color-border)] rounded-lg text-sm text-[var(--color-text)] hover:border-[var(--color-text-muted)] transition-all hover:-translate-y-0.5">Notes →</a>
      </div>
    </div>
  </section>

  <section class="max-w-3xl mx-auto px-4 sm:px-6 pb-20">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
      {[
        { t: 'Build', d: 'Products and systems.' },
        { t: 'Learn', d: 'Ideas, documented.' },
        { t: 'Share', d: 'Open notes.' },
      ].map((c, i) => (
        <div data-animate data-animate-delay={i * 80} class="p-5 bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl hover:border-[var(--color-text-muted)] transition-all hover:-translate-y-1">
          <h3 class="font-semibold mb-1 text-[var(--color-accent)]">{c.t}</h3>
          <p class="text-sm text-[var(--color-text-secondary)]">{c.d}</p>
        </div>
      ))}
    </div>
  </section>
</Base>
