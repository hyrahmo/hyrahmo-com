---
import Base from '../layouts/Base.astro';
---
<Base title="Home">
  <section class="min-h-[80vh] flex items-center">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 py-16 sm:py-24">
      <p data-animate class="font-mono text-sm text-[var(--color-text-muted)] mb-4">builder · thinker · systems</p>
      <h1 data-animate data-animate-delay="100" class="text-[clamp(2.5rem,7vw,4.5rem)] font-bold leading-[1.08] tracking-tight mb-6">
        I build things<br/>and share what I learn.
      </h1>
      <p data-animate data-animate-delay="200" class="text-lg text-[var(--color-text-secondary)] max-w-md mb-8">
        Projects, notes, and ideas — one place.
      </p>
      <div data-animate data-animate-delay="300" class="flex gap-3 flex-wrap">
        <a href="/projects" class="px-5 py-2.5 bg-[var(--color-accent)] text-[var(--color-bg)] rounded-lg font-medium text-sm hover:opacity-90 transition-all hover:-translate-y-0.5">Projects</a>
        <a href="/kb/" class="px-5 py-2.5 border border-[var(--color-border)] rounded-lg text-sm font-medium text-[var(--color-text)] hover:border-[var(--color-text-muted)] transition-all hover:-translate-y-0.5">Notes →</a>
      </div>
    </div>
  </section>

  <section class="max-w-3xl mx-auto px-4 sm:px-6 pb-16">
    <h2 data-animate class="text-2xl font-semibold tracking-tight mb-6">What I Do</h2>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
      {[
        { t: 'Build', d: 'Products and systems that work.' },
        { t: 'Learn', d: 'New ideas, documented as I go.' },
        { t: 'Share', d: 'Open notes and connections.' },
      ].map((c, i) => (
        <div data-animate data-animate-delay={100 + i * 100} class="p-5 bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl hover:border-[var(--color-text-muted)] transition-all hover:-translate-y-1">
          <h3 class="font-semibold mb-1 text-[var(--color-accent)]">{c.t}</h3>
          <p class="text-sm text-[var(--color-text-secondary)]">{c.d}</p>
        </div>
      ))}
    </div>
  </section>
</Base>
