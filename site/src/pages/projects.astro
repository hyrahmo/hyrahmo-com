---
import Base from '../layouts/Base.astro';
---
<Base title="Projects" description="Projects by HYRAHMO — things I've built.">
  <section class="page">
    <h1>Projects</h1>
    <p class="subtitle">Things I've built and worked on.</p>

    <div class="projects">
      <article class="project">
        <div class="project-header">
          <h2>hyrahmo.com</h2>
          <span class="tag">This site</span>
        </div>
        <p>Personal site and knowledge base. Astro + Quartz on Cloudflare Workers.</p>
      </article>

      <article class="project">
        <div class="project-header">
          <h2>More coming soon</h2>
          <span class="tag">WIP</span>
        </div>
        <p>New projects are in the works. Stay tuned.</p>
      </article>
    </div>
  </section>
</Base>

<style>
  .page {
    max-width: 680px;
    margin: 0 auto;
    padding: 6rem 2rem 4rem;
  }

  h1 {
    font-size: 2.5rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    margin-bottom: 0.5rem;
  }

  .subtitle {
    color: var(--color-text-muted);
    font-size: 1.1rem;
    margin-bottom: 3rem;
  }

  .projects {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .project {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 1.5rem 2rem;
    transition: border-color var(--transition);
  }

  .project:hover {
    border-color: var(--color-text-muted);
  }

  .project-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.5rem;
  }

  .project h2 {
    font-size: 1.2rem;
    font-weight: 600;
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
  }

  .project p {
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }
</style>
