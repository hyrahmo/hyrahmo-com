---
import Base from '../layouts/Base.astro';

const projects = [
  {
    title: 'hyrahmo.com',
    desc: 'This site. Astro + Quartz on Cloudflare Workers.',
    tag: 'Active',
    color: '#10b981',
    links: [
      { label: 'Notes', href: '/kb/' },
      { label: 'GitHub', href: 'https://github.com/hyrahmo/hyrahmo-com' },
    ],
  },
  {
    title: 'AI Research',
    desc: 'LLMs, agents, computer vision — notes and experiments.',
    tag: 'Active',
    color: '#8b5cf6',
    links: [
      { label: 'Notes', href: '/kb/en/engineering/ai/' },
    ],
  },
  {
    title: 'Quant Finance',
    desc: 'Algo trading, market models, HFT research.',
    tag: 'Planned',
    color: '#2563eb',
    links: [
      { label: 'Notes', href: '/kb/en/finance/quant/' },
    ],
  },
  {
    title: 'More coming',
    desc: 'New projects in the works.',
    tag: 'Soon',
    color: '#71717a',
    links: [],
  },
];
---
<Base title="Projects" description="Things I build and work on.">
  <section class="max-w-3xl mx-auto px-4 sm:px-6 py-16 sm:py-24">
    <h1 data-animate class="text-3xl sm:text-4xl font-bold tracking-tight mb-2">Projects</h1>
    <p data-animate data-animate-delay="100" class="text-[var(--color-text-secondary)] text-lg mb-10">Things I build and work on.</p>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      {projects.map((p, i) => (
        <div data-animate data-animate-delay={100 + i * 80} class="p-5 bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl hover:border-[var(--color-text-muted)] transition-all group">
          <div class="flex items-center gap-2 mb-2">
            <span class="w-2 h-2 rounded-full" style={`background: ${p.color}`}></span>
            <h2 class="font-semibold">{p.title}</h2>
            <span class="ml-auto font-mono text-xs text-[var(--color-text-muted)]">{p.tag}</span>
          </div>
          <p class="text-sm text-[var(--color-text-muted)] mb-3">{p.desc}</p>
          {p.links.length > 0 && (
            <div class="flex gap-3">
              {p.links.map(l => (
                <a href={l.href} target={l.href.startsWith('http') ? '_blank' : undefined} rel={l.href.startsWith('http') ? 'noopener' : undefined}
                   class="text-xs text-[var(--color-link)] hover:underline">{l.label} →</a>
              ))}
            </div>
          )}
        </div>
      ))}
    </div>
  </section>
</Base>
