---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<Base title="Blog" description="Thoughts on building products, AI research, quantitative finance, and systems thinking. Written by HYRAHMO.">
  <section class="max-w-3xl mx-auto px-4 sm:px-6 py-16 sm:py-24">
    <h1 data-animate class="text-3xl sm:text-4xl font-bold tracking-tight mb-10">Blog</h1>

    {posts.length === 0 ? (
      <p class="text-[var(--color-text-muted)]">No posts yet.</p>
    ) : (
      <div class="space-y-1">
        {posts.map((post, i) => (
          <a data-animate data-animate-delay={i * 60} href={`/blog/${post.id}/`}
             class="flex items-baseline gap-4 py-3 border-b border-[var(--color-border)] hover:text-[var(--color-link)] transition-colors group">
            <time class="font-mono text-xs text-[var(--color-text-muted)] shrink-0">{post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</time>
            <span class="font-medium group-hover:underline underline-offset-2">{post.data.title}</span>
          </a>
        ))}
      </div>
    )}
  </section>
</Base>
