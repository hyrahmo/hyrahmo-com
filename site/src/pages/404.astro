---
import Base from '../layouts/Base.astro';
---
<Base title="404">
  <section class="page">
    <h1>404</h1>
    <p>This page doesn't exist.</p>
    <a href="/" class="back">Go home &rarr;</a>
  </section>
</Base>

<style>
  .page {
    max-width: 680px;
    margin: 0 auto;
    padding: 20vh 2rem 4rem;
    text-align: center;
  }

  h1 {
    font-size: 5rem;
    font-weight: 700;
    letter-spacing: -0.05em;
    margin-bottom: 0.5rem;
  }

  p {
    color: var(--color-text-muted);
    font-size: 1.2rem;
    margin-bottom: 2rem;
  }

  .back {
    font-size: 1rem;
    color: var(--color-accent);
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 2px;
  }
</style>
