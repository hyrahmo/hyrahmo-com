---
import Base from '../../../layouts/Base.astro';
import { projects } from '../../../data/projects';
---
<Base title="Проекты" lang="ru" description="Проекты HYRAHMO.">
  <section class="max-w-3xl mx-auto px-4 sm:px-6 py-16 sm:py-24">
    <h1 data-animate class="text-3xl sm:text-4xl font-bold tracking-tight mb-2">Проекты</h1>
    <p data-animate data-animate-delay="100" class="text-[var(--color-text-secondary)] text-lg mb-10">То, что строю и над чем работаю.</p>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      {projects.map((p, i) => (
        <a href={`/ru/projects/${p.id}/`} data-animate data-animate-delay={100 + i * 80}
           class="block p-5 bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl hover:border-[var(--color-text-muted)] transition-all hover:-translate-y-0.5">
          <div class="flex items-center gap-2 mb-2">
            <span class="w-2 h-2 rounded-full" style={`background: ${p.color}`}></span>
            <h2 class="font-semibold text-[var(--color-accent)]">{p.ru.title}</h2>
            <span class="ml-auto font-mono text-xs text-[var(--color-text-muted)]">{p.ru.tag}</span>
          </div>
          <p class="text-sm text-[var(--color-text-secondary)]">{p.ru.desc}</p>
        </a>
      ))}
    </div>
  </section>
</Base>
