---
import Base from '../../layouts/Base.astro';
---
<Base title="Хирахмо" lang="ru" description="Хирахмо — проекты, исследования и база знаний на 8 языках.">
  <section class="min-h-[85vh] flex items-center">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 py-20 sm:py-32">
      <p data-animate class="font-mono text-sm text-[var(--color-text-muted)] mb-5">строю · думаю · систематизирую</p>
      <h1 data-animate data-animate-delay="100" class="text-[clamp(2.5rem,7vw,4rem)] font-bold leading-[1.1] tracking-tight mb-5">
        Строю и делюсь<br class="hidden sm:block"/> тем, что узнаю.
      </h1>
      <p data-animate data-animate-delay="200" class="text-[var(--color-text-secondary)] max-w-sm mb-8">
        Проекты, заметки и идеи — в одном месте.
      </p>
      <div data-animate data-animate-delay="300" class="flex gap-3">
        <a href="/ru/projects" class="px-5 py-2.5 rounded-lg font-medium text-sm hover:opacity-90 transition-all hover:-translate-y-0.5" style="background:var(--color-accent);color:var(--color-bg)">Проекты</a>
        <a href="/ru/blog" class="px-5 py-2.5 border border-[var(--color-border)] rounded-lg text-sm text-[var(--color-text)] hover:border-[var(--color-text-muted)] transition-all hover:-translate-y-0.5">Блог</a>
        <a href="/kb/ru/" class="px-5 py-2.5 border border-[var(--color-border)] rounded-lg text-sm text-[var(--color-text)] hover:border-[var(--color-text-muted)] transition-all hover:-translate-y-0.5">Заметки →</a>
      </div>
    </div>
  </section>

  <section class="max-w-3xl mx-auto px-4 sm:px-6 pb-20">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
      {[
        { t: 'Строю', d: 'Продукты и системы.' },
        { t: 'Учусь', d: 'Идеи и процесс.' },
        { t: 'Делюсь', d: 'Открытые заметки.' },
      ].map((c, i) => (
        <div data-animate data-animate-delay={i * 80} class="p-5 bg-[var(--color-surface)] border border-[var(--color-border)] rounded-xl hover:border-[var(--color-text-muted)] transition-all hover:-translate-y-1">
          <h3 class="font-semibold mb-1 text-[var(--color-accent)]">{c.t}</h3>
          <p class="text-sm text-[var(--color-text-secondary)]">{c.d}</p>
        </div>
      ))}
    </div>
  </section>
</Base>
