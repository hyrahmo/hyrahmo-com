---
import Base from '../layouts/Base.astro';
import CopyLink from '../components/CopyLink.astro';
---
<Base title="About" description="HYRAHMO builds products, explores complex systems, and shares research through an open multilingual knowledge base.">
  <section class="max-w-3xl mx-auto px-4 sm:px-6 py-16 sm:py-24">
    <h1 data-animate class="text-3xl sm:text-4xl font-bold tracking-tight mb-8">About</h1>
    <div data-animate data-animate-delay="100" class="space-y-5 text-lg leading-relaxed text-[var(--color-text-secondary)]">
      <p>I'm HYRAHMO. I build products, explore systems, and document what I learn.</p>
      <p>The <a href="/" class="text-[var(--color-link)] underline underline-offset-2">main site</a> is the polished side. The <a href="/kb/" class="text-[var(--color-link)] underline underline-offset-2">notes</a> are the raw side — a digital garden.</p>
      <p>Learning in public, building useful things, keeping it simple.</p>
    </div>
    <CopyLink lang="en" />
  </section>
</Base>
