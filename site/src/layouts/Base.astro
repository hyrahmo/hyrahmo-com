---
interface Props {
  title: string;
  description?: string;
  lang?: string;
}

const { title, description = 'HYRAHMO — personal site & knowledge base', lang = 'en' } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL('/og.png', Astro.site);

// i18n
const path = Astro.url.pathname;
const isRu = lang === 'ru';
const altLang = isRu ? 'en' : 'ru';
const altPath = isRu ? path.replace(/^\/ru/, '') || '/' : `/ru${path === '/' ? '' : path}`;
const altURL = new URL(altPath, Astro.site);
const prefix = isRu ? '/ru' : '';
const ogLocale = isRu ? 'ru_RU' : 'en_US';
---
<!doctype html>
<html lang={lang} data-theme="dark">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  <meta name="author" content="HYRAHMO" />
  <meta name="generator" content={Astro.generator} />
  <meta name="theme-color" content="#0a0a0a" />

  <!-- Canonical & Alternate -->
  <link rel="canonical" href={canonicalURL.href} />
  <link rel="alternate" hreflang={altLang} href={altURL.href} />
  <link rel="alternate" hreflang={lang} href={canonicalURL.href} />
  <link rel="alternate" hreflang="x-default" href={new URL(isRu ? altPath : path, Astro.site).href} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL.href} />
  <meta property="og:title" content={`${title} | HYRAHMO`} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage.href} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:site_name" content="HYRAHMO" />
  <meta property="og:locale" content={ogLocale} />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={`${title} | HYRAHMO`} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage.href} />

  <!-- Favicon: all sizes -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/png" sizes="32x32" href="/icons/favicon-32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/icons/favicon-16.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/icons/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

  <!-- Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "HYRAHMO",
    "url": "https://hyrahmo.com",
    "description": description,
    "inLanguage": [lang === 'ru' ? 'ru-RU' : 'en-US'],
    "author": {
      "@type": "Person",
      "name": "HYRAHMO",
      "url": "https://hyrahmo.com"
    }
  })} />

  <!-- Theme: prevent flash -->
  <script is:inline>
    const t = localStorage.getItem('theme') || 'dark';
    document.documentElement.setAttribute('data-theme', t);
    document.querySelector('meta[name="theme-color"]')?.setAttribute('content', t === 'dark' ? '#0a0a0a' : '#fafafa');
  </script>

  <title>{title} | HYRAHMO</title>
</head>
<body>
  <nav class="nav">
    <div class="nav-inner">
      <a href={`${prefix}/`} class="nav-logo">HYRAHMO</a>

      <!-- Desktop nav -->
      <div class="nav-links desktop-only">
        <a href={`${prefix}/about`}>{isRu ? 'Обо мне' : 'About'}</a>
        <a href={`${prefix}/projects`}>{isRu ? 'Проекты' : 'Projects'}</a>
        <a href="/kb/">{isRu ? 'Заметки' : 'Notes'}</a>
        <a href={`${prefix}/contact`}>{isRu ? 'Контакт' : 'Contact'}</a>
        <a href={altPath} class="lang-switch">{isRu ? 'EN' : 'RU'}</a>
        <button class="theme-toggle" id="theme-toggle-desktop" aria-label="Toggle theme">
          <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
          <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        </button>
      </div>

      <!-- Mobile controls -->
      <div class="mobile-controls mobile-only">
        <button class="theme-toggle" id="theme-toggle-mobile" aria-label="Toggle theme">
          <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
          <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        </button>
        <button class="burger" id="burger" aria-label="Menu">
          <svg class="burger-open" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12h18M3 6h18M3 18h18"/></svg>
          <svg class="burger-close" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
        </button>
      </div>
    </div>

    <!-- Mobile menu -->
    <div class="mobile-menu" id="mobile-menu">
      <a href={`${prefix}/about`}>{isRu ? 'Обо мне' : 'About'}</a>
      <a href={`${prefix}/projects`}>{isRu ? 'Проекты' : 'Projects'}</a>
      <a href="/kb/">{isRu ? 'Заметки' : 'Notes'}</a>
      <a href={`${prefix}/contact`}>{isRu ? 'Контакт' : 'Contact'}</a>
      <a href={altPath} class="lang-switch">{isRu ? 'EN' : 'RU'}</a>
    </div>
  </nav>

  <main>
    <slot />
  </main>

  <footer class="footer">
    <div class="footer-inner">
      <span>&copy; {new Date().getFullYear()} HYRAHMO</span>
      <div class="footer-links">
        <a href="https://github.com/hyrahmo" target="_blank" rel="noopener">GitHub</a>
        <a href={isRu ? 'https://x.com/hyrahmoru' : 'https://x.com/hyrahmo'} target="_blank" rel="noopener">X</a>
        <a href={isRu ? 'https://t.me/hyrahmoru' : 'https://t.me/hyrahmo'} target="_blank" rel="noopener">Telegram</a>
        <a href="/kb/">{isRu ? 'Заметки' : 'Notes'}</a>
      </div>
    </div>
  </footer>

  <script is:inline>
    // Theme toggle
    function toggleTheme() {
      const cur = document.documentElement.getAttribute('data-theme');
      const next = cur === 'dark' ? 'light' : 'dark';
      document.documentElement.setAttribute('data-theme', next);
      localStorage.setItem('theme', next);
      document.querySelector('meta[name="theme-color"]')?.setAttribute('content', next === 'dark' ? '#0a0a0a' : '#fafafa');
    }
    document.getElementById('theme-toggle-desktop')?.addEventListener('click', toggleTheme);
    document.getElementById('theme-toggle-mobile')?.addEventListener('click', toggleTheme);

    // Burger menu
    const burger = document.getElementById('burger');
    const menu = document.getElementById('mobile-menu');
    burger?.addEventListener('click', () => {
      const open = menu.classList.toggle('is-open');
      burger.classList.toggle('is-open', open);
      document.body.style.overflow = open ? 'hidden' : '';
    });
    // Close on link click
    menu?.querySelectorAll('a').forEach(a => {
      a.addEventListener('click', () => {
        menu.classList.remove('is-open');
        burger.classList.remove('is-open');
        document.body.style.overflow = '';
      });
    });
  </script>
</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    background: var(--color-bg-alpha);
    border-bottom: 1px solid var(--color-border);
  }

  .nav-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0.875rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-logo {
    font-weight: 700;
    font-size: 1.1rem;
    letter-spacing: 0.05em;
    flex-shrink: 0;
  }

  /* Desktop nav */
  .nav-links {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    font-size: 0.9rem;
  }

  .nav-links a {
    color: var(--color-text-muted);
    transition: color var(--transition);
  }

  .nav-links a:hover {
    color: var(--color-accent);
    opacity: 1;
  }

  .lang-switch {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    padding: 0.2rem 0.45rem;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    color: var(--color-text-muted) !important;
    transition: all var(--transition);
  }

  .lang-switch:hover {
    color: var(--color-accent) !important;
    border-color: var(--color-text-muted);
    opacity: 1 !important;
  }

  .theme-toggle {
    background: none;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 0.35rem;
    cursor: pointer;
    color: var(--color-text-muted);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all var(--transition);
    flex-shrink: 0;
  }

  .theme-toggle:hover {
    color: var(--color-accent);
    border-color: var(--color-text-muted);
  }

  [data-theme="dark"] .icon-sun { display: block; }
  [data-theme="dark"] .icon-moon { display: none; }
  [data-theme="light"] .icon-sun { display: none; }
  [data-theme="light"] .icon-moon { display: block; }

  /* Burger button */
  .burger {
    background: none;
    border: none;
    color: var(--color-text);
    cursor: pointer;
    padding: 0.25rem;
    display: flex;
    align-items: center;
  }

  .burger .burger-close { display: none; }
  .burger.is-open .burger-open { display: none; }
  .burger.is-open .burger-close { display: block; }

  .mobile-controls {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  /* Mobile menu — hidden on desktop, toggled on mobile */
  .mobile-menu {
    display: none;
    flex-direction: column;
    padding: 1rem 1.5rem 1.5rem;
    border-top: 1px solid var(--color-border);
    background: var(--color-bg);
  }

  .mobile-menu a {
    padding: 0.75rem 0;
    font-size: 1.1rem;
    color: var(--color-text-muted);
    border-bottom: 1px solid var(--color-border);
    transition: color var(--transition);
  }

  .mobile-menu a:last-child {
    border-bottom: none;
  }

  .mobile-menu a:hover {
    color: var(--color-accent);
    opacity: 1;
  }

  .mobile-menu .lang-switch {
    display: inline-block;
    width: fit-content;
    margin-top: 0.5rem;
    font-size: 0.85rem;
    padding: 0.3rem 0.6rem;
  }

  /* Show/hide by breakpoint */
  .mobile-only { display: none; }
  .desktop-only { display: flex; }

  @media (max-width: 768px) {
    .mobile-only { display: flex; }
    .desktop-only { display: none !important; }
    .mobile-menu.is-open { display: flex; }
  }

  main {
    padding-top: 3.5rem;
  }

  .footer {
    border-top: 1px solid var(--color-border);
    margin-top: 6rem;
  }

  .footer-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 2rem 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .footer-links {
    display: flex;
    gap: 1.25rem;
    flex-wrap: wrap;
  }

  .footer-links a {
    color: var(--color-text-muted);
    transition: color var(--transition);
  }

  .footer-links a:hover {
    color: var(--color-accent);
    opacity: 1;
  }
</style>
