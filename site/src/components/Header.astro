---
interface Props {
  lang?: string;
}

const { lang = 'en' } = Astro.props;
const isRu = lang === 'ru';
const prefix = isRu ? '/ru' : '';
const path = Astro.url.pathname;
const altPath = isRu ? path.replace(/^\/ru/, '') || '/' : `/ru${path === '/' ? '' : path}`;

const nav = [
  { href: `${prefix}/`, label: isRu ? 'Главная' : 'Home' },
  { href: `${prefix}/projects`, label: isRu ? 'Проекты' : 'Projects' },
  { href: `${prefix}/blog`, label: isRu ? 'Блог' : 'Blog' },
  { href: isRu ? '/kb/ru/' : '/kb/', label: isRu ? 'Заметки' : 'Notes' },
  { href: `${prefix}/contact`, label: isRu ? 'Контакт' : 'Contact' },
];

// For EN/RU: switch language on current page. For others: go to KB section.
const enPath = isRu ? altPath : path;
const ruPath = isRu ? path : altPath;

const langs = [
  { code: 'EN', href: enPath, full: 'English' },
  { code: 'RU', href: ruPath, full: 'Русский' },
  { sep: true },
  { code: '中文', href: '/kb/zh/', full: '中文' },
  { code: 'ES', href: '/kb/es/', full: 'Español' },
  { code: 'DE', href: '/kb/de/', full: 'Deutsch' },
  { code: 'FR', href: '/kb/fr/', full: 'Français' },
  { code: 'PT', href: '/kb/pt/', full: 'Português' },
  { code: 'AR', href: '/kb/ar/', full: 'العربية' },
];
---
<header id="header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-3 flex items-center justify-between">
    <a href={`${prefix}/`} class="text-lg font-bold tracking-wide text-[var(--color-accent)]">{isRu ? 'Хирахмо' : 'Hyrahmo'}</a>

    {/* Desktop */}
    <nav class="hidden md:flex items-center gap-5 text-sm">
      {nav.map(n => (
        <a href={n.href} class="text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors">{n.label}</a>
      ))}
      <div class="relative" id="lang-dropdown">
        <button id="lang-btn" class="font-mono text-xs px-2 py-0.5 border border-[var(--color-border)] rounded text-[var(--color-text-muted)] hover:text-[var(--color-accent)] hover:border-[var(--color-text-muted)] transition-all cursor-pointer flex items-center gap-1">
          {isRu ? 'RU' : 'EN'}
          <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
        </button>
        <div id="lang-menu" class="hidden absolute right-0 top-full mt-1 py-1 bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg shadow-lg min-w-[100px] z-50">
          {langs.map(l => l.sep
            ? <div class="border-t border-[var(--color-border)] my-1"></div>
            : <a href={l.href} class="block px-3 py-1.5 text-xs text-[var(--color-text-secondary)] hover:text-[var(--color-accent)] hover:bg-[var(--color-surface-elevated)] transition-colors">{l.full}</a>
          )}
        </div>
      </div>
      <button id="theme-desktop" aria-label="Toggle theme" class="p-1.5 border border-[var(--color-border)] rounded-lg text-[var(--color-text-muted)] hover:text-[var(--color-accent)] hover:border-[var(--color-text-muted)] transition-all cursor-pointer">
        <svg class="w-4 h-4 dark-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
        <svg class="w-4 h-4 light-icon hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
      </button>
    </nav>

    {/* Mobile */}
    <div class="flex md:hidden items-center gap-2">
      <button id="theme-mobile" aria-label="Toggle theme" class="p-1.5 border border-[var(--color-border)] rounded-lg text-[var(--color-text-muted)] cursor-pointer">
        <svg class="w-4 h-4 dark-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
        <svg class="w-4 h-4 light-icon hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
      </button>
      <button id="burger" aria-label="Menu" class="p-1 text-[var(--color-text)] cursor-pointer">
        <svg class="w-6 h-6 burger-open" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12h18M3 6h18M3 18h18"/></svg>
        <svg class="w-6 h-6 burger-close hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="hidden flex-col px-4 sm:px-6 pb-4 border-t border-[var(--color-border)] bg-[var(--color-bg)] md:hidden">
    {nav.map(n => (
      <a href={n.href} class="py-3 text-base text-[var(--color-text-secondary)] border-b border-[var(--color-border)] last:border-b-0 hover:text-[var(--color-accent)] transition-colors">{n.label}</a>
    ))}
    <div class="flex flex-wrap gap-2 mt-3">
      {langs.filter(l => !l.sep).map(l => (
        <a href={l.href} class="font-mono text-xs px-2 py-1 border border-[var(--color-border)] rounded text-[var(--color-text-muted)]">{l.code}</a>
      ))}
    </div>
  </div>
</header>
