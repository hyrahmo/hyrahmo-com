---
import SocialIcons from './SocialIcons.astro';

interface Props {
  lang?: string;
}

const { lang = 'en' } = Astro.props;
const isRu = lang === 'ru';

const langs = [
  { code: 'EN', href: '/' },
  { code: 'RU', href: '/ru/' },
  { code: '中文', href: '/kb/zh/' },
  { code: 'ES', href: '/kb/es/' },
  { code: 'DE', href: '/kb/de/' },
  { code: 'FR', href: '/kb/fr/' },
  { code: 'PT', href: '/kb/pt/' },
  { code: 'AR', href: '/kb/ar/' },
];
---
<footer class="border-t border-[var(--color-border)] mt-20">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-8 space-y-5 text-sm text-[var(--color-text-muted)]">
    {/* Row 1: copyright + socials */}
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
      <span>&copy; {new Date().getFullYear()} {isRu ? 'Хирахмо' : 'HYRAHMO'}</span>
      <SocialIcons lang={lang} size={16} />
    </div>

    {/* Row 2: support links */}
    <div class="flex flex-wrap items-center gap-4 text-xs">
      <a href="/kb/index.xml" class="hover:text-[var(--color-accent)] transition-colors flex items-center gap-1">
        <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/></svg>
        RSS
      </a>
      {isRu
        ? <a href="https://boosty.to/hyrahmo" target="_blank" rel="noopener" class="hover:text-[var(--color-accent)] transition-colors">Boosty</a>
        : <a href="https://buymeacoffee.com/hyrahmo" target="_blank" rel="noopener" class="hover:text-[var(--color-accent)] transition-colors">Buy me a coffee</a>
      }
    </div>

    {/* Row 3: languages */}
    <div class="flex items-center gap-3 text-xs">
      <span class="opacity-50">{isRu ? 'Язык:' : 'Lang:'}</span>
      {langs.map(l => (
        <a href={l.href} class="hover:text-[var(--color-accent)] transition-colors">{l.code}</a>
      ))}
    </div>
  </div>
</footer>
