{
  "name": "hyrahmo-com",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "rm -rf dist",
    "install:kb": "cd kb && npm install --ignore-scripts",
    "build:site": "pnpm --filter @hyrahmo/site run build",
    "build:kb": "cd kb && npx quartz build -o ../dist/kb",
    "build:merge": "node scripts/merge.mjs",
    "build": "npm run clean && npm run install:kb && npm run build:site && npm run build:kb && npm run build:merge",
    "dev:site": "pnpm --filter @hyrahmo/site run dev",
    "dev:kb": "cd kb && npx quartz build --serve --port 8080",
    "preview": "npm run build && npx wrangler dev",
    "deploy": "npm run build && npx wrangler deploy"
  },
  "devDependencies": {
    "wrangler": "^4.80.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "sharp", "workerd"]
  }
}
